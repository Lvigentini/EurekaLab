    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "playwright": "^1.58.2",
    "typescript": "^5.6.3",
    "vite": "^8.0.3"
  }
}
